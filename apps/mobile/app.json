{
  "expo": {
    "name": "SolarCheck",
    "slug": "solarcheck",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "solarcheck",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.solarcheck.app"
    },
    "android": {
      "package": "com.solarcheck.app",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION"]
    },
    "plugins": ["expo-location"],
    "extra": {
      "eas": {
        "projectId": "solarcheck-local-mvp"
      }
    }
  }
}
