{
  "name": "solarcheck",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @solarcheck/web",
    "dev:web": "npm run dev -w @solarcheck/web",
    "dev:mobile": "npm run start -w @solarcheck/mobile",
    "build": "npm run build -w @solarcheck/core && npm run build -w @solarcheck/web",
    "test": "npm run test -w @solarcheck/core",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
